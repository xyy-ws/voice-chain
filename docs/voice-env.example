# voice-chain runtime env example

# feature flags
VOICE_MVP_ENABLED=true
VOICE_TELEGRAM_ENABLED=true
VOICE_DISCORD_ENABLED=true

# ASR
VOICE_ASR_PROVIDER=local_whisper
VOICE_ASR_LOCAL_COMMAND=python3
VOICE_ASR_LOCAL_SCRIPT=/ABSOLUTE/PATH/TO/voice-chain/src/tools/faster-whisper-transcribe.py
VOICE_ASR_LOCAL_MODEL=base
VOICE_ASR_LOCAL_DEVICE=cpu
VOICE_ASR_LOCAL_COMPUTE_TYPE=int8
VOICE_ASR_LOCAL_BEAM_SIZE=1
VOICE_ASR_LOCAL_VAD_FILTER=true
VOICE_ASR_LOCAL_TIMEOUT_MS=180000
VOICE_ASR_LANGUAGE=zh
VOICE_ASR_PROMPT=以下是中文口语，请尽量按原话转写，不要脑补。

# Telegram
VOICE_TELEGRAM_BOT_TOKEN=YOUR_TELEGRAM_BOT_TOKEN
VOICE_TELEGRAM_CHAT_ID=YOUR_CHAT_ID

# Discord
VOICE_DISCORD_BOT_TOKEN=YOUR_DISCORD_BOT_TOKEN
VOICE_DISCORD_CHANNEL_ID=YOUR_CHANNEL_ID
